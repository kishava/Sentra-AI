# Copy to .env.local for local dev: npm run env:setup
# Vercel production: set only the "Vercel required" block in Project → Environment Variables.
# Provider keys (AIML, Bright Data, Speechmatics): npm run secrets:sync → Supabase vault (see docs/SECRETS_VAULT.md).

# --- Vercel required (production) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Or legacy: NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=
# Or legacy: SUPABASE_SERVICE_ROLE_KEY=
SENTRA_APP_URL=https://your-project.vercel.app
CRON_SECRET=

# --- Local / optional ---
SENTRA_TIMEZONE=Asia/Colombo
SENTRA_ALLOW_DEMO_FALLBACK=false
SENTRA_AGENT_PROVIDER=

# --- Provider keys (local dev + secrets:sync; omit on Vercel if using vault) ---
AIML_API_KEY=
AIML_BASE_URL=
FEATHERLESS_API_KEY=
FEATHERLESS_BASE_URL=
BRIGHT_DATA_API_KEY=
BRIGHT_DATA_SERP_ZONE=
BRIGHT_DATA_WEB_UNLOCKER_ZONE=
BRIGHT_DATA_SCRAPER_ZONE=
BRIGHT_DATA_BROWSER_ZONE=
BRIGHT_DATA_MCP_ENABLED=true
SPEECHMATICS_API_KEY=
