# Copy to .env.local — use placeholders only; never commit real keys.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SECRET_KEY=your_supabase_secret_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_jwt

# Provider keys: Supabase vault (npm run secrets:sync) or set in host env for deploy.

SENTRA_APP_URL=http://localhost:3001
CRON_SECRET=

SENTRA_TIMEZONE=Asia/Colombo

# Model + TTS tuning (non-secret)
AIML_MODEL_ANALYSIS=gpt-4o-mini
AIML_MODEL_CHAT=gpt-4o
AIML_MODEL_SEARCH=gpt-4o-search-preview
AIML_MODEL_SEARCH_MINI=gpt-4o-mini-search-preview
AIML_SEARCH_CONTEXT_SIZE=medium
AIML_MODEL_INTENT=gpt-4o-mini
AIML_MODEL_WORLD=gpt-4o
AIML_MODEL_VISION=gpt-4o
AIML_MODEL_TRANSCRIBE=whisper-1
AIML_TTS_MODEL=openai/tts-1
AIML_TTS_VOICE=nova
AIML_TTS_SPEED=1.08
SPEECHMATICS_TTS_VOICE=sarah
SPEECHMATICS_ASR_URL=https://asr.api.speechmatics.com/v2
SENTRA_AUTOMATION_WEBHOOK_URL=

FEATHERLESS_MODEL_CHAT=meta-llama/Llama-3.3-70B-Instruct
FEATHERLESS_MODEL_FAST=Qwen/Qwen2.5-7B-Instruct
FEATHERLESS_MODEL_VISION=google/gemma-3-27b-it

BRIGHT_DATA_API_KEY=
BRIGHT_DATA_MANAGEMENT_KEY=
BRIGHT_DATA_CACHE_TTL_SECONDS=900
BRIGHT_DATA_SERP_ENDPOINT=https://api.brightdata.com/request
BRIGHT_DATA_SERP_ZONE=
BRIGHT_DATA_WEB_UNLOCKER_ENDPOINT=https://api.brightdata.com/request
BRIGHT_DATA_WEB_UNLOCKER_ZONE=
BRIGHT_DATA_SCRAPER_ENDPOINT=https://api.brightdata.com/request
BRIGHT_DATA_SCRAPER_ZONE=
BRIGHT_DATA_BROWSER_ENDPOINT=https://api.brightdata.com/request
BRIGHT_DATA_BROWSER_ZONE=
BRIGHT_DATA_STUDIO_COLLECTOR_ID=
BRIGHT_DATA_MCP_URL=
BRIGHT_DATA_MCP_GROUPS=
BRIGHT_DATA_MCP_ENABLED=true
