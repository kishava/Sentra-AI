# Supabase — leave empty for local-only mode; fill for cloud auth + DB
NEXT_PUBLIC_SUPABASE_URL=
# New publishable key (sb_publishable_…) or legacy anon JWT
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: secret key (sb_secret_…) or legacy service_role JWT
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Optional: direct Postgres URL for `npm run db:migrate` only — never commit
DATABASE_URL=

# AI/ML API (hackathon) — primary LLM gateway (OpenAI-compatible)
# Get key: https://aimlapi.com — never commit real keys
# --- Deploy: only these are required on Vercel/host after `npm run secrets:sync` ---
# Provider keys (AIML, Featherless, Bright Data) live in Supabase platform_env vault.

SENTRA_APP_URL=http://localhost:3001

# Optional local dev fallback (omit on deploy if synced to Supabase)
AIML_API_KEY=
AIML_BASE_URL=https://api.aimlapi.com/v1
AIML_MODEL_ANALYSIS=gpt-4o-mini
AIML_MODEL_CHAT=gpt-4o
# Search-capable model for general chat (no temperature param — handled automatically)
AIML_MODEL_SEARCH=gpt-4o-search-preview
AIML_MODEL_SEARCH_MINI=gpt-4o-mini-search-preview
AIML_SEARCH_CONTEXT_SIZE=medium
AIML_MODEL_INTENT=gpt-4o-mini
AIML_MODEL_WORLD=gpt-4o
AIML_MODEL_VISION=gpt-4o
AIML_MODEL_TRANSCRIBE=whisper-1
AIML_TTS_MODEL=openai/tts-1
AIML_TTS_VOICE=nova
AIML_TTS_SPEED=1.08

# Featherless — open-source inference for documents & agent workflows
FEATHERLESS_API_KEY=
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_MODEL_CHAT=meta-llama/Llama-3.3-70B-Instruct
FEATHERLESS_MODEL_FAST=Qwen/Qwen2.5-7B-Instruct
FEATHERLESS_MODEL_VISION=google/gemma-3-27b-it
SENTRA_APP_URL=http://localhost:3001

SENTRA_TIMEZONE=Asia/Colombo

BRIGHT_DATA_API_KEY=
BRIGHT_DATA_MANAGEMENT_KEY=
BRIGHT_DATA_CACHE_TTL_SECONDS=900
BRIGHT_DATA_SERP_ENDPOINT=https://api.brightdata.com/request
BRIGHT_DATA_SERP_ZONE=
BRIGHT_DATA_WEB_UNLOCKER_ENDPOINT=https://api.brightdata.com/request
BRIGHT_DATA_WEB_UNLOCKER_ZONE=
BRIGHT_DATA_SCRAPER_ENDPOINT=

# Legacy (optional) — voice uses AIML TTS when AIML_API_KEY is set
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
